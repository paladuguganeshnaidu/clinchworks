rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasRole(role) {
      let r = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return signedIn() && (
        r == role ||
        (r is string && r.matches('(?i).*' + role + '.*')) ||
        (r is list && role in r)
      );
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isReception() {
      return hasRole('reception');
    }

    function isStaff() {
      return isAdmin() || isReception();
    }

    // Users: allow a signed-in user to manage their own profile,
    // but prevent self-service role escalation.
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());

      allow create: if signedIn()
        && request.auth.uid == uid
        && !('role' in request.resource.data);

      allow update: if signedIn()
        && request.auth.uid == uid
        && (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);

      allow delete: if isAdmin();
    }

    match /courses/{emailId} {
      allow read, write: if signedIn() && request.auth.token.email != null && request.auth.token.email.lower() == emailId.lower();
      allow read, write: if isAdmin();
    }

    match /certificates/{certId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.email != null
        && request.resource.data.email.lower() == request.auth.token.email.lower()
        && get(/databases/$(database)/documents/courses/$(request.auth.token.email.lower())).data.courses[request.resource.data.courseId].examPassed == true;
      allow update, delete: if isAdmin();
    }

    // Bookings: public create (lead form), staff-only read/update/delete.
    match /bookings/{bookingId} {
      allow create: if true;

      allow read: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }

    // Contact messages: public create, staff-only read/update/delete.
    match /contactMessages/{messageId} {
      allow create: if true;

      allow read: if isStaff();

      allow update: if isStaff();

      allow delete: if isAdmin();
    }
  }
}
